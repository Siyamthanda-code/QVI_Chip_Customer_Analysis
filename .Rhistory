setwd("C:/Users/Amooo/Videos/Quantium_Forage")
getwd()
install.packages("readxl")
install.packages("dplyr")
install.packages("ggplot2")
install.packages("stringr")
install.packages("lubridate")
library(readxl)
library(dplyr)
library(ggplot2)
library(stringr)
library(lubridate)
# -------------------------------------------------
# 1. LOAD THE DATA
# -------------------------------------------------
# Load the transaction and purchase behaviour data
# Make sure the file names are EXACTLY correct
transaction_data <- read_excel("QVI Transaction Data.xlsx")
purchase_behaviour <- read_excel("QVI Purchase Behaviour.xlsx")
# -------------------------------------------------
# 2. INITIAL DATA EXPLORATION & CLEANING
# -------------------------------------------------
# Look at the first few rows of each dataset
head(transaction_data)
head(purchase_behaviour)
# Check the structure (column names and types)
str(transaction_data)
str(purchase_behaviour)
# Check for missing values
colSums(is.na(transaction_data))
colSums(is.na(purchase_behaviour))
# Check for and remove any duplicate transactions
cat("Number of duplicate rows:", sum(duplicated(transaction_data)), "\n")
transaction_data <- distinct(transaction_data) # Removes duplicates
# Convert the DATE column from Excel's number format to a proper date
transaction_data$DATE <- as.Date(transaction_data$DATE, origin = "1899-12-30")
# -------------------------------------------------
# 3. FEATURE ENGINEERING
# -------------------------------------------------
# Extract pack size (the numbers) from the product name
transaction_data$PACK_SIZE <- as.numeric(str_extract(transaction_data$PROD_NAME, "\\d+"))
# Extract the first word of the product name as the brand
transaction_data$BRAND <- word(transaction_data$PROD_NAME, 1)
# Clean up and standardize some brand names
transaction_data <- transaction_data %>%
  mutate(BRAND = case_when(
    BRAND == "Red" ~ "RRD",
    BRAND == "Snbts" ~ "Sunbites",
    BRAND == "Infzns" ~ "Infuzions",
    BRAND == "WW" ~ "Woolworths",
    BRAND == "Smith" ~ "Smiths",
    BRAND == "Dorito" ~ "Doritos",
    BRAND == "GrnWves" ~ "Grain Waves",
    BRAND == "Natural" | BRAND == "NCC" ~ "Natural Chip Co",
    TRUE ~ BRAND
  ))
# -------------------------------------------------
# 4. MERGE THE DATASETS
# -------------------------------------------------
# Combine transaction data with customer data
merged_data <- transaction_data %>%
  left_join(purchase_behaviour, by = "LYLTY_CARD_NBR")
# -------------------------------------------------
# 5. ANALYZE CUSTOMER SEGMENTS
# -------------------------------------------------
# Calculate key metrics for each customer segment
segment_analysis <- merged_data %>%
  group_by(LIFESTAGE, PREMIUM_CUSTOMER) %>%
  summarise(
    total_customers = n_distinct(LYLTY_CARD_NBR),
    total_sales = sum(TOT_SALES),
    total_transactions = n(),
    avg_transactions_per_customer = total_transactions / total_customers,
    avg_sales_per_customer = total_sales / total_customers,
    .groups = "drop"
  ) %>%
  arrange(desc(total_sales))
# Display the top segments by total sales
print("Top Customer Segments by Total Sales:")
print(head(segment_analysis, 10))
# Analyze brand preferences by segment
brand_by_segment <- merged_data %>%
  group_by(LIFESTAGE, PREMIUM_CUSTOMER, BRAND) %>%
  summarise(sales = sum(TOT_SALES), .groups = "drop") %>%
  group_by(LIFESTAGE, PREMIUM_CUSTOMER) %>%
  mutate(brand_share = sales / sum(sales) * 100) %>%
  arrange(LIFESTAGE, PREMIUM_CUSTOMER, desc(brand_share))
# Analyze pack size preferences by segment
pack_by_segment <- merged_data %>%
  group_by(LIFESTAGE, PREMIUM_CUSTOMER, PACK_SIZE) %>%
  summarise(sales = sum(TOT_SALES), .groups = "drop") %>%
  group_by(LIFESTAGE, PREMIUM_CUSTOMER) %>%
  mutate(pack_share = sales / sum(sales) * 100) %>%
  arrange(LIFESTAGE, PREMIUM_CUSTOMER, desc(pack_share))
# -------------------------------------------------
# 6. CREATE VISUALIZATIONS
# -------------------------------------------------
# Plot 1: Top 10 Segments by Total Sales
top_10_segments <- segment_analysis %>%
  arrange(desc(total_sales)) %>%
  slice_head(n = 10) %>%
  mutate(segment_label = paste(LIFESTAGE, PREMIUM_CUSTOMER, sep = " - "))
ggplot(top_10_segments, aes(x = reorder(segment_label, total_sales), y = total_sales)) +
  geom_bar(stat = "identity", fill = "steelblue") +
  coord_flip() +
  labs(
    title = "Top 10 Customer Segments by Total Chip Sales",
    x = "Customer Segment (Lifestage - Premium)",
    y = "Total Sales ($)"
  ) +
  scale_y_continuous(labels = scales::dollar_format())
# Plot 2: Brand Preferences for the Top Segment
# First, find the name of the top segment
top_segment_name <- top_10_segments$segment_label[1]
# Get the brand data for just that top segment
top_segment_brands <- brand_by_segment %>%
  filter(paste(LIFESTAGE, PREMIUM_CUSTOMER, sep = " - ") == top_segment_name) %>%
  slice_head(n = 5) # Top 5 brands
ggplot(top_segment_brands, aes(x = reorder(BRAND, brand_share), y = brand_share, fill = BRAND)) +
  geom_bar(stat = "identity") +
  coord_flip() +
  labs(
    title = paste("Top 5 Brands for", top_segment_name),
    x = "Brand",
    y = "Share of Spend (%)"
  ) +
  theme(legend.position = "none")
# -------------------------------------------------
# 7. SAVE YOUR RESULTS
# -------------------------------------------------
# Save the main analysis table to a CSV file
write.csv(segment_analysis, "customer_segment_analysis.csv", row.names = FALSE)
cat("\nAnalysis complete! Your results are saved in 'customer_segment_analysis.csv'.")
cat("\nPlots have been generated in the 'Plots' window.")
local({fn<-choose.files(filters=Filters[c('R','txt','All'),],index=4)
file.show(fn,header=fn,title='')})
